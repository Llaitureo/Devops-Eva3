
DB_PORT=3306

# =========== #
# RECOMMENDED #
# =========== #

CURRENT_UID=1000
CURRENT_GID=1000

DB_PASSWORD_R=root
DB_NAME=innovatech_db
DB_USERNAME=innovatech_user
DB_PASSWORD=innovatech_pass

# Por defecto, no funcionará sin el workflow de GitHub Actions,
#   ya que se necesita el ACCOUNT_ID para construir la URL del ECR.

# Para eso existe una legacy version de CI y CD en formato txt, si es que se quiere ocupar.
AWS_ECR_REGISTRY=aws_registry_plano

# por defecto se usará el último tag, pero se puede cambiar por el hash del commit o por un tag específico.
#   En el cd.yml se define como github.sha para usar el hash del commit.

# Netamente referencial, por si se quiere ocupar el docker-compose
#   sin pasar por el workflow de GitHub Actions,
#   se puede usar el tag "latest" para referenciar la última imagen disponible en el ECR.
TAG_VERSION=latest

